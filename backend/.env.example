# Calmindra Deployed Environment Configuration Example
# Copy this file to .env and fill in the credentials.

# Neo4j AuraDB Configuration
NEO4J_URI=neo4j+s://<your-auradb-id>.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# Google Gemini API Configuration (Vertex AI)
GEMINI_API_KEY=your-gemini-api-key

# Upstash Serverless Redis Configuration
REDIS_URL=redis://:<your-upstash-password>@<your-upstash-endpoint>:<port>
