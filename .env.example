NEO4J_URI=neo4j+s://<your-auradb-id>.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=<your-password>

GEMINI_API_KEY=<your-gemini-api-key>
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

REDIS_URL=redis://localhost:6379

# Comma-separated frontend origins allowed by CORS.
FRONTEND_ORIGINS=http://localhost:3000

# Shared secret required on every protected backend request.
# Must match BACKEND_API_SECRET in the Next.js frontend deployment.
BACKEND_API_SECRET=replace-with-the-same-secret-as-frontend
